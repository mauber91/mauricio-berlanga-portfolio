{
  "name": "mauricio-berlanga-portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run validate:social-cards && tsc -b && vite build && node scripts/prepare-sites.mjs",
    "build:github-pages": "npm run validate:social-cards && tsc -b && vite build --mode github-pages && node scripts/prepare-github-pages.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "validate:social-cards": "node scripts/validate-social-cards.mjs"
  },
  "dependencies": {
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@vitejs/plugin-react": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "globals": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vite": "latest"
  }
}
